# Security + caching headers for static hosts that read `_headers`
# (Cloudflare Pages, Netlify). Copied verbatim into dist/ by Vite.

/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: no-referrer
  X-Frame-Options: DENY
  Content-Security-Policy: default-src 'self'; base-uri 'none'; object-src 'none'; img-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self'; frame-ancestors 'none'

# Hashed build assets are immutable — cache them aggressively to cut bandwidth.
/assets/*
  Cache-Control: public, max-age=31536000, immutable
