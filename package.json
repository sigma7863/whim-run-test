{
  "name": "whim-run-test",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "An interactive GPGPU particle field rendered with Three.js, built and tooled with bun.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "bun test src",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "three": "^0.180.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2",
    "@playwright/test": "1.61.0",
    "@types/bun": "^1.3.14",
    "@types/three": "^0.180.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
